{
  "name": "@spoud/sdm-proto-api",
  "version": "0.0.0",
  "description": "SDM Proto API - Protobuf-ES and ts-proto TypeScript types",
  "typesVersions": {
    "*": {
      "ts-proto/*": ["ts-proto/*"],
      "*": ["dist/*"]
    }
  },
  "files": [
    "dist/",
    "ts-proto/"
  ],
  "scripts": {
    "generate": "cd .. && buf generate",
    "build": "npm run generate && tsc && tsc -p tsconfig.ts-proto.json",
    "clean": "rm -rf dist/ ts-proto/ src/gen/ src/gen-ts-proto/"
  },
  "peerDependencies": {
    "@bufbuild/protobuf": "^2.0.0",
    "@connectrpc/connect": "^2.0.0"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.50.0",
    "@bufbuild/protobuf": "^2.6.0",
    "@bufbuild/protoc-gen-es": "^2.6.0",
    "@connectrpc/connect": "^2.0.0",
    "@grpc/grpc-js": "^1.14.4",
    "@types/node": "^26.1.0",
    "ts-proto": "^2.11.8",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "declaration": true,
    "sourceMap": true,
    "outDir": "ts-proto",
    "rootDir": "src/gen-ts-proto",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/gen-ts-proto/**/*.ts"]
}
